# ───────────────────────── Trade Solver .gitignore ─────────────────────────

# Virtual environments
venv/
.venv/

# Python build artifacts
__pycache__/
*.py[cod]
build/
dist/
*.egg-info/

# Runtime state & config — regenerated by the app on launch
window_config.json
window_config.json.bak
presets/

# Backups / archives (kept locally)
*.zip

# Superseded docs (kept locally)
README_OLD.md

# Editor / OS noise
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
